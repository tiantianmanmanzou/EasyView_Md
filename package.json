{
  "name": "markdown-preview-wysiwyg",
  "displayName": "Markdown-preview-wysiwyg",
  "description": "Markdown-preview-wysiwyg supports native inline suggestion via native TextEditor + decorations/CodeLens/hover/overlay.",
  "version": "1.0.54",
  "publisher": "zhangxy",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "file:///Users/zhangxy/GenAI/Markdown-preview-wysiwyg"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "native-inline-suggestion",
    "decorations",
    "codelens",
    "hover",
    "overlay"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:mdx",
    "onCommand:inlineMd.openEditor",
    "onCommand:inlineMd.openNativeEditor"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "inlineMd.markdownEditor",
        "displayName": "Markdown-preview-wysiwyg (Rich Editor)",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          },
          {
            "filenamePattern": "*.mdx"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "inlineMd.openEditor",
        "title": "Open with Markdown-preview-wysiwyg (Rich Editor)",
        "category": "Markdown-preview-wysiwyg",
        "icon": "$(preview)"
      },
      {
        "command": "inlineMd.openNativeEditor",
        "title": "Open in Native Markdown Editor",
        "category": "Markdown-preview-wysiwyg"
      },
      {
        "command": "inlineMd.exportHtmlLight",
        "title": "Export to HTML (Light)",
        "category": "Markdown-preview-wysiwyg"
      },
      {
        "command": "inlineMd.exportHtmlDark",
        "title": "Export to HTML (Dark)",
        "category": "Markdown-preview-wysiwyg"
      },
      {
        "command": "inlineMd.exportPdfLight",
        "title": "Export to PDF (Light)",
        "category": "Markdown-preview-wysiwyg"
      },
      {
        "command": "inlineMd.exportPdfDark",
        "title": "Export to PDF (Dark)",
        "category": "Markdown-preview-wysiwyg"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "inlineMd.openEditor",
          "when": "resourceLangId == markdown || resourceLangId == mdx || resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdx",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "inlineMd.openEditor",
          "when": "resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdx",
          "group": "navigation@1"
        },
        {
          "command": "inlineMd.openNativeEditor",
          "when": "resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdx",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "key": "ctrl+z",
        "command": "inlineMd.undo",
        "when": "activeCustomEditorId == 'inlineMd.markdownEditor'"
      },
      {
        "key": "ctrl+shift+z",
        "command": "inlineMd.redo",
        "when": "activeCustomEditorId == 'inlineMd.markdownEditor'"
      },
      {
        "key": "ctrl+y",
        "command": "inlineMd.redo",
        "when": "activeCustomEditorId == 'inlineMd.markdownEditor'"
      }
    ],
    "configurationDefaults": {
      "[markdown]": {
        "editor.fontFamily": "\"Sarasa Mono SC\", \"Sarasa Fixed SC\", \"SF Mono\", Menlo, Monaco, \"Courier New\", monospace"
      },
      "[mdx]": {
        "editor.fontFamily": "\"Sarasa Mono SC\", \"Sarasa Fixed SC\", \"SF Mono\", Menlo, Monaco, \"Courier New\", monospace"
      }
    },
    "configuration": {
      "title": "Markdown-preview-wysiwyg",
      "properties": {
        "inlineMd.csvDelimiter": {
          "type": "string",
          "enum": [
            ",",
            ";",
            "auto"
          ],
          "default": "auto",
          "enumDescriptions": [
            "Comma (US, UK, etc.)",
            "Semicolon (Russia, Germany, France, etc.)",
            "Auto-detect based on system locale (may not work correctly)"
          ],
          "description": "CSV delimiter to use when exporting tables"
        },
        "inlineMd.nativeDecorations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable lightweight inline markdown decorations in the native VS Code editor."
        },
        "inlineMd.nativeDecorations.mermaid.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable experimental Mermaid flowchart previews in the native VS Code editor. Disabled by default because VS Code requires a visible contributed view for the webview renderer."
        },
        "inlineMd.nativeDecorations.tables.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable conservative Markdown table styling in the native VS Code editor without replacing table source text."
        },
        "inlineMd.nativeEditor.forceMonospaceFont": {
          "type": "boolean",
          "default": true,
          "description": "Force Markdown native source editors to use a CJK-aware monospace font family when opened from Markdown-preview-wysiwyg."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --production",
    "package": "vsce package",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "vscode-test",
    "test:e2e:pw": "npx playwright test",
    "lint": "oxlint src/",
    "clean": "rm -rf dist/extension.js dist/extension.js.map dist/webview.js dist/webview.js.map"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.23",
    "@types/markdown-it": "^14.1.2",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.0.0",
    "buffer": "^6.0.3",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@benrbray/prosemirror-math": "^1.0.0",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.12",
    "@fontsource/roboto-mono": "^5.2.8",
    "codemirror": "^6.0.2",
    "copy-to-clipboard": "^3.3.3",
    "gemoji": "^8.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.28",
    "lodash": "^4.17.23",
    "markdown-it": "^14.1.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "mermaid": "^11.12.1",
    "pdf-lib": "^1.17.1",
    "pdfmake": "^0.3.4",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-gapcursor": "^1.4.0",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.2",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.1",
    "prosemirror-view": "^1.41.4",
    "refractor": "^3.6.0",
    "scroll-into-view-if-needed": "^3.1.0",
    "uuid": "^11.1.0"
  },
  "private": true
}
